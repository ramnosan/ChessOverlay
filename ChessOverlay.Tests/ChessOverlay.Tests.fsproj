<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="TestHelpers.fs" />
    <Compile Include="DomainTests.fs" />
    <Compile Include="AttackCalculatorTests.fs" />
    <Compile Include="BoardReaderTests.fs" />
    <Compile Include="TemplatePieceDetectionTests.fs" />
    <Compile Include="CrapMetricTests.fs" />
    <Compile Include="DryDuplicationTests.fs" />
    <Compile Include="ArchitectureViewTests.fs" />
    <Compile Include="ProgramTests.fs" />
    <Compile Include="BoardSelectionWindowTests.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" Version="6.0.4">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.4">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ChessOverlay\ChessOverlay.fsproj" />
    <ProjectReference Include="..\ChessOverlay.Quality\ChessOverlay.Quality.fsproj" />
  </ItemGroup>

</Project>

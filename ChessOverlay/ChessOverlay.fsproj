<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Domain.fs" />
    <Compile Include="AttackCalculator.fs" />
    <Compile Include="BoardReading.fs" />
    <Compile Include="TemplatePieceDetection.fs" />
    <Compile Include="OverlayWindow.fs" />
    <Compile Include="OverlayController.fs" />
    <Compile Include="BoardSelectionWindow.fs" />
    <Compile Include="ChromeBoardDetector.fs" />
    <Compile Include="ChromeBoardSelectionDialog.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="FieldTemplates\*.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>ChessOverlay.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

</Project>
